# ── 默认聊天模型配置 ──────────────────────────
# provider 是模型服务商或网关；model 是该 provider 下的模型 ID。
# 前端选择 provider 后，会覆盖这里的默认聊天 provider。
# LLM_PROVIDER=deepseek          # deepseek | kilo | ollama
# LLM_MODEL_ID=deepseek-chat     # 留空则使用 provider preset 默认 model

# 通用 OpenAI-compatible 显式覆盖；通常留空，使用 config.yaml 的 provider preset。
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=                  # 留空则使用 provider preset 默认 base_url

# provider 专用配置（可选）
# DEEPSEEK_API_KEY=sk-xxx
# KILO_API_KEY=sk-xxx

# ── 摘要模型配置（可选，不填则复用默认聊天模型）──
# 摘要模型不受前端 provider 选择影响。
# SUMMARY_LLM_PROVIDER=ollama
# SUMMARY_LLM_API_KEY=local
# SUMMARY_LLM_BASE_URL=http://host.docker.internal:11434/v1
# SUMMARY_LLM_MODEL_ID=qwen2.5:7b

# ── Telegram Bot（可选）──────────────────────
TELEGRAM_BOT_TOKEN=
# 必须显式设置为 true 才会启动 Long Polling，避免多个实例抢同一个 bot。
TELEGRAM_POLLING_ENABLED=false

# ── Server ───────────────────────────────────
APP_PORT=9090
